{
  "name": "wxchat",
  "version": "2.0.0",
  "description": "微信文件传输助手 - Cloudflare Workers 全栈重构版",
  "private": true,
  "type": "module",
  "main": "worker/index.js",
  "scripts": {
    "build": "node build.js",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:local": "wrangler d1 execute wxchat --local --file=./database/schema.sql",
    "db:remote": "wrangler d1 execute wxchat --remote --file=./database/schema.sql",
    "db:init": "wrangler d1 execute wxchat --file=./database/schema.sql",
    "tail": "wrangler tail"
  },
  "dependencies": {
    "hono": "^4.7.2"
  },
  "devDependencies": {
    "wrangler": "^3.114.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "cloudflare-workers",
    "hono",
    "wechat",
    "file-transfer",
    "d1",
    "r2",
    "pwa"
  ],
  "license": "CC-BY-NC-SA-4.0"
}
